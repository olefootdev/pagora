# PAGORA — variáveis públicas do frontend (prefixo VITE_ é exposto ao client)
# Copie esse arquivo para .env.local e preencha com as chaves do seu projeto Supabase.
# A anon key é segura no frontend; a service_role NUNCA vai aqui.
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Número da central PAGORA no WhatsApp (E.164 sem '+').
# Recebe os pedidos disparados pelos botões "Enviar via WhatsApp" nas summary screens.
VITE_PAGORA_WPP_NUMBER=5511999999999

# Analytics. Vazio = não carrega o snippet (zero requests pra Google / Meta em dev).
# GA4 measurement ID — formato G-XXXXXXXXXX
VITE_GA4_ID=
# Meta Pixel ID — formato numérico de 15-16 dígitos
VITE_META_PIXEL_ID=
